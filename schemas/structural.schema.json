{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://democracy-index.cz/schemas/structural.schema.json",
  "title": "StructuralBaseline",
  "description": "Quarterly structural baseline derived from established annual indices (V-Dem, EIU, Freedom House, RSF, TI, WJP). One file per quarter at data/structural/YYYY-Qx.json.",
  "type": "object",
  "required": ["quarter", "computed_at", "pillars", "sources"],
  "additionalProperties": false,
  "properties": {
    "quarter": {
      "type": "string",
      "pattern": "^[0-9]{4}-Q[1-4]$"
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "pillars": {
      "type": "object",
      "required": ["electoral", "governance", "judicial", "media", "civil", "corruption"],
      "additionalProperties": false,
      "properties": {
        "electoral": { "type": "number", "minimum": 0, "maximum": 100 },
        "governance": { "type": "number", "minimum": 0, "maximum": 100 },
        "judicial": { "type": "number", "minimum": 0, "maximum": 100 },
        "media": { "type": "number", "minimum": 0, "maximum": 100 },
        "civil": { "type": "number", "minimum": 0, "maximum": 100 },
        "corruption": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "year", "value", "url"],
        "additionalProperties": false,
        "properties": {
          "index": { "type": "string", "description": "V-Dem|EIU|FH-FitW|FH-NiT|RSF|TI-CPI|WJP|EC-RoL|BTI" },
          "year": { "type": "integer", "minimum": 2000, "maximum": 2100 },
          "value": { "type": "number" },
          "pillar": { "type": "string", "enum": ["electoral", "governance", "judicial", "media", "civil", "corruption"] },
          "url": { "type": "string", "format": "uri" },
          "notes": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Optional methodology notes specific to this quarter (e.g. why a value differs from prior quarter)."
    }
  }
}
